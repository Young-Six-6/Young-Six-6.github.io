{
  "name": "valaxy-blog",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:ssg",
    "build:spa": "valaxy build",
    "build:ssg": "valaxy build --ssg",
    "dev": "valaxy",
    "rss": "valaxy rss",
    "serve": "vite preview",
    "deploy": "npm run build:ssg && gh-pages --clean --dist dist"
  },
  // 核心新增：强制所有依赖使用兼容的 katex@0.16.9
