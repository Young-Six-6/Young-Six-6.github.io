    "valaxy": {
      "katex": "0.16.9"
    },
    "valaxy-theme-yun": {
      "katex": "0.16.9"
    }
  },
  "dependencies": {
    "@waline/client": "3.4.1",
    "valaxy": "0.26.10",
    "valaxy-addon-waline": "^0.2.1",
    "valaxy-theme-yun": "0.26.10",
    // 显式声明 katex 依赖，确保版本锁定
    "katex": "0.16.9"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.3"
